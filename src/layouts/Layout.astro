---
import '../styles/main.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
const baseUrl = "/ORC_WEBSITE_REAL";
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/logo.svg`} />
    <title>Okanagan Rovercraft</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href={`${baseUrl}/assets/images/ORC - Landscape Banner.webp`} as="image" type="image/webp" fetchpriority="high" />
    <link href="https://fonts.googleapis.com/css2?family=Gothic+A1:wght@400;500;600&family=Monomaniac+One&display=swap" rel="stylesheet" />
</head>
<body>
    <div class="landing-page">
        <Header />
        <main>
            <slot />
        </main>
        <Footer />
    </div>
    <ImageLightbox />
</body>
</html>
