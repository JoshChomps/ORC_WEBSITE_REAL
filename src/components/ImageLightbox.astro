---
---
<div id="lightbox-overlay" class="lightbox-overlay">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
    <div class="lightbox-content" id="lightbox-content">
        <img id="lightbox-img" src="" alt="Expanded view" />
    </div>
</div>

<style>
    .lightbox-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(12px);
        z-index: 9999;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .lightbox-overlay.active {
        display: flex;
        opacity: 1;
    }

    .lightbox-content {
        max-width: 90%;
        max-height: 90%;
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        border-radius: 8px;
    }

    .lightbox-content img {
        display: block;
        max-width: 100%;
        max-height: 90vh;
        object-fit: contain;
        cursor: zoom-in;
        transform: scale(0.95);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), transform-origin 0.1s ease;
        box-shadow: 0 0 40px rgba(0, 0, 0, 0.6);
    }

    .lightbox-overlay.active .lightbox-content img {
        transform: scale(1);
    }

    /* Zoomed State */
    .lightbox-content.zoomed img {
        transform: scale(2.5);
        cursor: zoom-out;
        transition: transform 0.3s ease, transform-origin 0s;
    }

    .lightbox-close {
        position: absolute;
        top: 30px;
        right: 40px;
        background: rgba(255, 255, 255, 0.1);
        border: none;
        color: white;
        font-size: 40px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        z-index: 10000;
        transition: all 0.2s ease;
    }

    .lightbox-close:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.1);
    }
</style>

<script>
    function setupLightbox() {
        const overlay = document.getElementById('lightbox-overlay');
        const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
        const content = document.getElementById('lightbox-content');
        const closeBtn = document.querySelector('.lightbox-close');
        
        if (!overlay || !lightboxImg || !content) return;

        let isZoomed = false;

        // Open lightbox
        document.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            if (target.tagName === 'IMG' && target.classList.contains('expandable-image')) {
                const img = target as HTMLImageElement;
                lightboxImg.src = img.src;
                lightboxImg.alt = img.alt;
                overlay.style.display = 'flex';
                overlay.offsetHeight;
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
        });

        // Toggle Zoom
        lightboxImg.addEventListener('click', (e) => {
            e.stopPropagation();
            isZoomed = !isZoomed;
            if (isZoomed) {
                content.classList.add('zoomed');
                updatePan(e);
            } else {
                content.classList.remove('zoomed');
                lightboxImg.style.transformOrigin = 'center';
            }
        });

        // Pan Logic
        const updatePan = (e: MouseEvent | PointerEvent) => {
            if (!isZoomed) return;
            const rect = content.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;
            lightboxImg.style.transformOrigin = `${x}% ${y}%`;
        };

        content.addEventListener('mousemove', (e) => {
            if (isZoomed) updatePan(e);
        });

        // Close lightbox
        const closeLightbox = () => {
            isZoomed = false;
            content.classList.remove('zoomed');
            overlay.classList.remove('active');
            setTimeout(() => {
                overlay.style.display = 'none';
                lightboxImg.src = '';
                lightboxImg.style.transformOrigin = 'center';
                document.body.style.overflow = '';
            }, 300);
        };

        overlay.addEventListener('click', (e) => {
            if (e.target === overlay || e.target === content) closeLightbox();
        });

        if (closeBtn) closeBtn.addEventListener('click', closeLightbox);

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && overlay.classList.contains('active')) {
                closeLightbox();
            }
        });
    }

    document.addEventListener('DOMContentLoaded', setupLightbox);
</script>
