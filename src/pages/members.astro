                <div class="member-info">
                   <h2 style="font-family: 'Monomaniac One', sans-serif;">Coming Soon</h2>
                   <p>Project leads and team members will be updated shortly.</p>
                </div>
            </div>
        </div>
    </div>
</Layout>
