---
import Layout from '../layouts/Layout.astro';
const baseUrl = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout>
    <div style="text-align: center; padding: 100px 20px;">
        <h1 style="font-size: 80px; color: #ffd800; font-family: 'Monomaniac One', sans-serif;">404</h1>
        <h2 style="font-family: 'Monomaniac One', sans-serif;">Oops! This page is currently under construction.</h2>
        <p style="font-family: 'Gothic A1', sans-serif; margin-bottom: 40px;">We're working hard to bring you more content soon.</p>
        <a href={`${baseUrl}/`} style="padding: 15px 30px; background: #00606b; color: white; text-decoration: none; border-radius: 40px; font-weight: bold;">Return Home</a>
    </div>
</Layout>
