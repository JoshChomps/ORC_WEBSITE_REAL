---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import '../styles/sponsors.css';
import '../styles/pdf-viewer.css';
const rawBase = import.meta.env.BASE_URL;
const baseUrl = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<Layout>
    <section class="content_section" id="CS1" style="height:45%">
        <div class="content">
            <h2 style="max-width: 650px;">Sponsors don’t just help us build rovers, they build future professionals. </h2>
            <p class="content_text">
                Through contributions of materials, expertise, and financial support, our sponsors help students gain experience in design, engineering, business, and science. Financial and material contributions go directly to prototyping, designing, manufacturing, testing, and travel, allowing Okanagan Rover Craft to build a competitive rover for a world-class competition.
                We are incredibly grateful to our current sponsors who have already invested in the future of STEM professionals. Your contributions make an incredible difference and are truly appreciated.
            </p>
            <div class="image-frame">
                <img src={`${baseUrl}/assets/images/IMG_1259.jpg`} alt="Group Photo" loading="lazy" decoding="async" class="expandable-image" />
            </div>
        </div>
    </section>

    <section class="content_section" id="SponsorGrid" style="background-color: white; color: black; padding: 80px 0;">
        <div id="sponser-cont">
            <h2 style="color: var(--mountain-bg); font-size: 42px;">Our Sponsors</h2>
            <p style="font-size: 18px; margin-bottom: 40px; opacity: 0.8;">Thank you for supporting our team!</p>
            <div class="sponser-items">
                <div class="sponser-display">
                    <div class="sponser-img"><img src={`${baseUrl}/assets/sponsors/altar.webp`} alt="Altar Metal Fab Co." loading="lazy" decoding="async" /></div>
                    <p>Altar Metal Fab Co.</p>
                </div>
                <div class="sponser-display">
                    <div class="sponser-img"><img src={`${baseUrl}/assets/sponsors/polymaker.webp`} alt="Polymaker" loading="lazy" decoding="async" /></div>
                    <p>Polymaker</p>
                </div>
                <div class="sponser-display">
                    <div class="sponser-img"><img src={`${baseUrl}/assets/sponsors/stepperonline.webp`} alt="Stepper Online" loading="lazy" decoding="async" /></div>
                    <p>Stepper Online</p>
                </div>
            </div>
        </div>
    </section>

    <section class="content_section" id="CS2" style="background-color: var(--mountain-bg); color: white;">
        <div class="content" style="margin-top: -60px;">
            <h2>How to get involved</h2>
            <div class="content-flex" style="display: flex; gap: 40px; align-items: flex-start; flex-wrap: wrap;">
                <p class="content_text" style="flex: 1; min-width: 300px;">
                    Looking to get involved in the future of Okanagan Rover Craft? We are always looking for passionate collaborators to join our mission. If you represent an organization looking to empower a team of young professionals, our outreach team would be thrilled to discuss the benefits of partnering with Okanagan Rover Craft with you! Sponsoring our team provides your organization with brand visibility while directly supporting our team's goals. A partnership with Okanagan Rover Craft allows you to connect with top student talent in STEM fields and support both our craft, and our team's future. If you are interested in supporting us, get involved today by filling out our contact form or emailing us at outreach@okanaganrovercraft.ca.
                </p>
                <div class="pdf-viewer-container" style="flex: 1; min-width: 300px; margin-top: 20px;">
                    <div class="pdf-viewer-frame">
                        <iframe id="sponsorship-pdf" src={`${baseUrl}/documents/ORC SPONSORSHIP PACKAGE 2026 - 4 (compressed V3).pdf#toolbar=0`} title="ORC Sponsorship Package Preview"></iframe>
                        <div class="pdf-overlay">
                            <button id="expand-pdf-btn" class="expand-button">
                                <span class="expand-icon">⛶</span> View Full Screen
                            </button>
                        </div>
                    </div>
                    <a href={`${baseUrl}/documents/ORC SPONSORSHIP PACKAGE 2026 - 4 (compressed V3).pdf`} download class="SP_button">
                        Download Sponsorship Package
                        <span class="arrow">→</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <div id="pdf-modal" class="pdf-modal">
        <div class="pdf-modal-container">
            <button class="pdf-modal-close" aria-label="Close modal">&times;</button>
            <iframe id="expanded-pdf" src="" title="Expanded Sponsorship Package"></iframe>
        </div>
    </div>

    <script>
        const modal = document.getElementById('pdf-modal');
        const expandBtn = document.getElementById('expand-pdf-btn');
        const expandedIframe = document.getElementById('expanded-pdf');
        const closeBtn = document.querySelector('.pdf-modal-close');
        const originalSrc = `${import.meta.env.BASE_URL}documents/ORC SPONSORSHIP PACKAGE 2026 - 4 (compressed V3).pdf`;

        const openModal = () => {
            if (modal && expandedIframe) {
                // @ts-ignore
                expandedIframe.src = `${originalSrc}#toolbar=1`;
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
        };

        const closeModal = () => {
            if (modal && expandedIframe) {
                modal.classList.remove('active');
                setTimeout(() => {
                    // @ts-ignore
                    expandedIframe.src = "";
                    document.body.style.overflow = '';
                }, 300);
            }
        };

        if (expandBtn) expandBtn.addEventListener('click', (e) => {
            e.preventDefault();
            openModal();
        });
        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        if (modal) {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modal && modal.classList.contains('active')) {
                closeModal();
            }
        });
    </script>
    
    <section class="content_section" style="background-color: white; padding: 40px 0 120px;">
        <ContactForm />
    </section>
</Layout>
